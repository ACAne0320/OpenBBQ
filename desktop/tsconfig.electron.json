{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "types": ["node"],
    "rootDir": ".",
    "outDir": "./dist-electron",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.electron.tsbuildinfo"
  },
  "include": ["electron/**/*.ts", "electron/**/*.cts", "src/lib/mockData.ts", "src/lib/types.ts"],
  "exclude": ["electron/**/__tests__/**/*.ts"]
}
