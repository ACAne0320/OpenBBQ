{
  "name": "openbbq-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:electron": "concurrently -k -s first -n vite,electron \"pnpm dev\" \"wait-on http://127.0.0.1:5173 && pnpm electron:dev\"",
    "electron:dev": "pnpm electron:build && cross-env OPENBBQ_RENDERER_URL=http://127.0.0.1:5173 electron dist-electron/main.js",
    "electron:build": "tsc -p tsconfig.electron.json",
    "electron:start": "pnpm build && electron dist-electron/main.js",
    "build": "tsc -b && vite build && pnpm electron:build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run --passWithNoTests --exclude tests/**",
    "test:watch": "vitest",
    "e2e:install": "playwright install chromium",
    "e2e": "playwright test"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  }
}
